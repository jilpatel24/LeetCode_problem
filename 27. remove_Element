import java.util.Arrays;

public class p1{
public static void main(String[] args) {
    int[] arr = {3,2,2,3};
    int val = 3;
  
  System.out.println(Arrays.toString(arr));
   int ans = in_place_mod(arr, val);
   System.out.println(ans);
}
 static int in_place_mod(int[] arr,int val){
  int k=0;

  for (int i = 0; i < arr.length; i++) {
      if(arr[i] != val){
        arr[k] = arr[i];
        k++;
      }
  }
  return k;
 }
}
      
